{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^up-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "首页"
      }
    },
    {
      "path": "pages/cart/cart",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "购物车"
      }
    },
    {
      "path": "pages/mine/mine",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/login/login",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "登录注册"
      }
    },
    {
      "path": "pages/message/message",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "消息中心"
      }
    },
    {
      "path": "pages/address/list",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "收货地址"
      }
    },
    {
      "path": "pages/address/form",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "地址表单"
      }
    },
    {
      "path": "pages/setting/setting",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "设置"
      }
    },
    {
      "path": "pages/setting/userInfo",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "个人信息"
      }
    },
    {
      "path": "pages/setting/changePhone",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "更换绑定手机号"
      }
    },
    {
      "path": "pages/setting/changePassword",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "修改登录密码"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "社交新零售商城",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F7F8FA",
    "backgroundTextStyle": "dark",
    "app-plus": {
      "animationType": "slide-in-right",
      "animationDuration": 200,
      "background": "#F7F8FA",
      "bounce": "vertical",
      "titleNView": false
    },
    "h5": {
      "titleNView": false
    },
    "mp-weixin": {
      "background": "#F7F8FA"
    }
  },
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["pagesSub/goods", "pagesSub/order"]
    },
    "pages/mine/mine": {
      "network": "all",
      "packages": ["pagesSub/member", "pagesSub/order"]
    },
    "pages/cart/cart": {
      "network": "all",
      "packages": ["pagesSub/order"]
    }
  },
  "tabBar": {
    "custom": true,
    "color": "#999999",
    "selectedColor": "#FF6A00",
    "borderStyle": "white",
    "backgroundColor": "#FFFFFF",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "",
        "selectedIconPath": ""
      },
      {
        "pagePath": "pagesSub/goods/category/categoryHome",
        "text": "分类",
        "iconPath": "",
        "selectedIconPath": ""
      },
      {
        "pagePath": "pages/cart/cart",
        "text": "购物车",
        "iconPath": "",
        "selectedIconPath": ""
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "",
        "selectedIconPath": ""
      }
    ]
  },
